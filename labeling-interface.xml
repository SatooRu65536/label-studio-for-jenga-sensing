<!-- Label Studio のプロジェクト設定の Labeling Interface -->
<View>
    <Header value="Video + Sensor Annotation" />

    <Video
        name="video"
        value="$video"
        sync="ts"
    />

    <TimeSeriesLabels name="behavior" toName="ts">
        <Label value="Label A" />
        <Label value="Label B" />
        <Label value="Label C" />
        <Label value="Label D" />
        <Label value="Label E" />
        <Label value="Other" />
    </TimeSeriesLabels>

    <TimeSeries
        name="ts"
        value="$timeseries"
        valueType="url"
        timeColumn="timestamp"
        sync="video"
        fixedScale="true"
        height="250"
    >
        <MultiChannel>
            <Channel column="player_1" />
            <Channel column="player_2" />
            <Channel column="player_3" />
            <Channel column="player_4" />
        </MultiChannel>
    </TimeSeries>
</View>
